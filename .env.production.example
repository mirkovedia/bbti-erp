NODE_ENV=production
# Puerto interno del contenedor (3001-3005 ya ocupados en el servidor).
# En producción NO se publica: Traefik enruta https://proyectos.bbtecnologia.com
# al puerto 3006 por la red interna de Docker. El mapeo 3006:3006 del compose
# es solo para desarrollo local / pruebas internas.
PORT=3006

# PostgreSQL — AWS RDS, base documental_platform, schema proyectos.
# Prisma opera ÚNICAMENTE sobre ese schema (via ?schema=).
# OJO: si la contraseña tiene caracteres especiales, URL-encodearlos.
# En desarrollo local: postgresql://postgres:postgres@host.docker.internal:5433/bbti?schema=gestion_proyectos
DATABASE_URL=postgresql://USER:PASSWORD@HOST:5432/documental_platform?schema=proyectos&sslmode=require

# Sesiones JWT (mínimo 32 caracteres aleatorios; generar con: openssl rand -base64 48)
JWT_SECRET=

# "true" en producción (detrás de Traefik con HTTPS; Traefik reenvía X-Forwarded-Proto)
COOKIE_SECURE=true

# Cloudflare R2 (privado, compatible S3). Presigned URLs contra el endpoint
# S3 API de R2 (NO un custom domain del bucket). Bucket recomendado: proyectos-prod.
# CORS requerido en el bucket (lo configura el ingeniero):
#   Origin:  https://proyectos.bbtecnologia.com
#   Methods: GET, PUT, HEAD
#   Headers: content-type, content-md5, x-amz-*, x-amz-checksum-*
#   Expose:  etag
R2_ENDPOINT_URL=https://ACCOUNT_ID.r2.cloudflarestorage.com
R2_BUCKET=proyectos-prod
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_REGION=auto

# Límite de subida de archivos en MB (MVP: 25; ajustable a 50/100 sin tocar código).
# El valor viaja FIRMADO en las presigned URLs: el storage rechaza cuerpos de otro tamaño.
MAX_UPLOAD_MB=25

# Auth del endpoint de cron (generar con: openssl rand -hex 24)
CRON_SECRET=
